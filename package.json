{
  "name": "oktech-web",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "homepage": "https://oktech.jp/",
  "repository": {
    "type": "git",
    "url": "https://github.com/oktechjp/oktech.jp.git"
  },
  "bugs": {
    "url": "https://github.com/oktechjp/oktech.jp/issues"
  },
  "scripts": {
    "dev": "astro dev --host",
    "build": "astro build",
    "preview": "astro preview --host",
    "start": "npm run build && npm run preview",
    "knip": "knip",
    "format": "prettier --write . --log-level warn",
    "typecheck": "npm-run-all -p typecheck:astro typecheck:tsc",
    "typecheck:tsc": "tsc --noEmit",
    "typecheck:astro": "astro check",
    "checks": "npm-run-all format typecheck knip",
    "import": "tsx ./scripts/import-data",
    "og-cache": "tsx scripts/manage-og-cache.ts",
    "extract-themes": "tsx scripts/extract-theme-colors.ts",
    "analyze-bundle": "ANALYZE_BUNDLE=true astro build && echo '\n📊 Bundle Analysis Complete! 📊\n\n🔗 View stats at: http://localhost:4321/stats.html\n' && npm run preview",
    "test": "npm run test:dev",
    "test:dev": "playwright test",
    "test:screenshots": "rm -rf test/screenshots/output && TEST_TYPE=screenshots playwright test",
    "test:build": "npm run build && npm run knip && npm run typecheck && TEST_BUILD=true playwright test",
    "test:dist": "TEST_BUILD=true playwright test",
    "generate-types": "wrangler types"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/rss": "^4.0.18",
    "@fontsource/lexend": "^5.2.11",
    "@playwright/test": "^1.61.0",
    "@react-spring/web": "^10.1.1",
    "@rollup/plugin-yaml": "^4.1.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/hast": "^3.0.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "daisyui": "^5.5.23",
    "dotenv": "^17.4.2",
    "fuse.js": "^7.4.2",
    "gray-matter": "^4.0.3",
    "knip": "^5.76.3",
    "mdast-util-to-string": "^4.0.0",
    "npm-run-all": "^4.1.5",
    "osm-static-maps": "^4.0.2",
    "playwright": "^1.61.1",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "puppeteer": "^24.43.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-photo-album": "^3.6.0",
    "reading-time": "^1.5.0",
    "remark-breaks": "^4.0.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.33.5",
    "slugify": "^1.6.9",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.22.4",
    "tw-to-css": "^0.0.12",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0",
    "vite": "^8.1.0",
    "vite-plugin-svgr": "^5.2.0",
    "wrangler": "^4.106.0",
    "yaml": "^2.8.2",
    "yet-another-react-lightbox": "^3.32.0"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.1"
  }
}
