---
import { getCollection } from "astro:content";
import ArticleLayout from "@/layouts/ArticleLayout.astro";
import MarkdownPageLayout from "@/layouts/MarkdownPageLayout.astro";

export async function getStaticPaths() {
  const markdownPages = await getCollection("markdownPages");

  return markdownPages.map((page) => ({
    params: { markdownSlug: page.id },
    props: { markdown: page.data.filePath },
  }));
}

const { markdown } = Astro.props;
const isArticle = markdown.startsWith("articles/");
---

{isArticle ? <ArticleLayout markdown={markdown} /> : <MarkdownPageLayout markdown={markdown} />}
