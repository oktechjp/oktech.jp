---
import PageLayout from "@/layouts/PageLayout.astro";
import Container from "@/components/Common/Container";
import MarkdownContent from "@/components/Common/MarkdownContent.astro";
import ArticleAuthorBar from "@/components/Article/ArticleAuthorBar";
import ArticleNextLink from "@/components/Article/ArticleNextLink";
import { parseAuthor } from "@/utils/author";
import { LuClock } from "react-icons/lu";
import { getCollection } from "astro:content";

interface Props {
  markdown: string;
}

const { markdown } = Astro.props;

const markdownFiles = import.meta.glob("/content/**/*.md");
const fullPath = `/content/${markdown}`;
const module = (await markdownFiles[fullPath]()) as any;
const { frontmatter } = module;

const author = frontmatter?.author ? parseAuthor(frontmatter.author) : undefined;

// Compute next article (next older by date)
const pages = await getCollection("markdownPages");
const articlePages = pages.filter((p) => p.data.filePath.startsWith("articles/"));

const articles = await Promise.all(
  articlePages.map(async (p) => {
    const mod = (await markdownFiles[`/content/${p.data.filePath}`]()) as any;
    const fm = mod.frontmatter;
    return { id: p.id, title: fm?.title ?? p.id, date: fm?.date, filePath: p.data.filePath };
  }),
);

const sorted = articles.sort((a, b) => {
  if (a.date && b.date) return new Date(b.date).getTime() - new Date(a.date).getTime();
  return a.title.localeCompare(b.title);
});

const currentIndex = sorted.findIndex((a) => a.filePath === markdown);
const next = sorted[currentIndex + 1];
const nextArticle = next ? { title: next.title, href: `/${next.id}` } : undefined;

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
}
---

<PageLayout className="pt-32 pb-22">
  <Container thin>
    <div class="mb-20 flex flex-col gap-4">
      <h1 class="title">{frontmatter?.title}</h1>
      {
        (author || frontmatter?.date || frontmatter?.readingTime) && (
          <div class="text-base-content/60 flex flex-wrap items-center gap-2 text-sm">
            {author && <ArticleAuthorBar author={author} />}
            {author && (frontmatter?.date || frontmatter?.readingTime) && (
              <span class="text-base-content/30">&middot;</span>
            )}
            {frontmatter?.date && (
              <span class="flex items-center gap-1">
                <LuClock className="h-3.5 w-3.5" />
                {formatDate(frontmatter.date)}
              </span>
            )}
            {frontmatter?.date && frontmatter?.readingTime && (
              <span class="text-base-content/30">&middot;</span>
            )}
            {frontmatter?.readingTime && <span>{frontmatter.readingTime}</span>}
          </div>
        )
      }
    </div>
    <div class="prose prose-lg max-w-none">
      <MarkdownContent markdown={markdown} />
    </div>
    <ArticleNextLink title={nextArticle?.title} href={nextArticle?.href} />
  </Container>
</PageLayout>
