---
import BlobParagraphsClient from "./BlobParagraphs";
import type { BlobParagraphCta } from "./BlobParagraphShared";
import { getResponsiveImage } from "@/utils/responsiveImage";

interface Paragraph {
  title: string;
  text: string;
  images: string[];
  blobs?: number[];
  cta?: BlobParagraphCta;
}

interface Props {
  paragraphs: Paragraph[];
  blobs?: number[];
}

const { paragraphs, blobs } = Astro.props;

const processedParagraphs = await Promise.all(
  paragraphs.map(async (paragraph) => ({
    ...paragraph,
    images: await Promise.all(
      paragraph.images.map((path) => getResponsiveImage(path, "blobSlideshow")),
    ),
  })),
);
---

<BlobParagraphsClient paragraphs={processedParagraphs} blobs={blobs} client:load />
